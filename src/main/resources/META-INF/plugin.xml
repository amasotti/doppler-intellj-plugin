<idea-plugin>
    <id>com.tonihacks.doppler-intellij</id>
    <name>Doppler</name>
    <vendor url="https://github.com/amasotti/doppler-intellj" email="toniomasotti@gmail.com">Antonio Masotti</vendor>

    <description><![CDATA[
        Inject Doppler-managed secrets into JetBrains run configurations and browse / edit them from a tool window.
        <br/>
        Requires the Doppler CLI to be installed and authenticated (<code>doppler login</code>).
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <!--
        Gradle family injector — optional so the plugin loads cleanly in IDEs without Gradle
        support (PyCharm, PhpStorm, WebStorm Community, etc.).
    -->
    <depends optional="true" config-file="doppler-gradle.xml">com.intellij.gradle</depends>

    <!--
        Java family injector — optional so the plugin loads cleanly in IDEs without Java
        support (WebStorm, PhpStorm, GoLand, etc.). Covers all JVM run configs that build
        a JavaParameters: Application, JUnit, TestNG, Spring Boot Application.
    -->
    <depends optional="true" config-file="doppler-java.xml">com.intellij.java</depends>

    <resource-bundle>messages.DopplerBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="com.tonihacks.doppler.settings.DopplerSettingsState"/>
        <projectService serviceImplementation="com.tonihacks.doppler.service.DopplerProjectService"/>
        <projectService serviceImplementation="com.tonihacks.doppler.injection.core.OverrideTracker"/>
        <!-- isLogByDefault="false": notifications never go to the persistent Event Log
             panel — they fade with the balloon. Defense in depth for spec §11.2: even if a
             future caller accidentally passes a value-bearing string to DopplerNotifier,
             nothing lingers in the user's Event Log. -->
        <notificationGroup id="Doppler" displayType="BALLOON" isLogByDefault="false"/>
        <!--
            Settings → Tools → Doppler.
            nonDefaultProject="true" hides the page from the synthetic default project.
            parentId="tools" places it under the Tools group.
            IntelliJ Platform injects the Project into the constructor automatically.
        -->
        <projectConfigurable
            parentId="tools"
            instance="com.tonihacks.doppler.settings.DopplerSettingsConfigurable"
            id="com.tonihacks.doppler.settings"
            bundle="messages.DopplerBundle"
            key="settings.title"
            nonDefaultProject="true"/>

        <!--
            Doppler tool window — browse and edit secrets without leaving the IDE.
            Anchor "right" matches the common placement for project-level tool windows.
        -->
        <toolWindow id="Doppler"
            anchor="right"
            factoryClass="com.tonihacks.doppler.ui.toolwindow.DopplerToolWindowFactory"
            icon="/META-INF/pluginIcon.svg"/>
    </extensions>
</idea-plugin>
